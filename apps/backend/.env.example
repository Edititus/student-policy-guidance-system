# OpenAI API Key (Required for AI features)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# AI Provider: 'openai' or 'huggingface' (default: huggingface)
AI_PROVIDER=huggingface

# Hugging Face API Key (Required when AI_PROVIDER=huggingface)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# HuggingFace generation model override (optional)
# Default: Qwen/Qwen2.5-72B-Instruct (free tier, reliable)
# Other options: meta-llama/Llama-3.2-3B-Instruct, HuggingFaceH4/zephyr-7b-beta
# HF_GENERATION_MODEL=Qwen/Qwen2.5-72B-Instruct

# Retrieval similarity threshold override (optional)
# OpenAI default: 0.7 | HuggingFace default: 0.30
# Lower = more results returned; raise if you see irrelevant answers
# RETRIEVAL_THRESHOLD=0.30

# Server Configuration
PORT=4000
